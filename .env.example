# Skopiuj do .env i dostosuj wartości.

# --- PostgreSQL ---
POSTGRES_USER=phonebook
POSTGRES_PASSWORD=phonebook
POSTGRES_DB=phonebook
POSTGRES_PORT=5432

# --- JWT (token dostępu) ---
JWT__Issuer=ContactManager
JWT__Audience=ContactManager
JWT__Key=zmien-ten-klucz-na-dlugi-losowy-sekret-min-32-znaki
JWT__ExpiryMinutes=15

# --- Refresh token (token odświeżania, cookie HttpOnly) ---
RefreshToken__ExpiryDays=7
RefreshToken__CookieName=refreshToken
RefreshToken__CookieSecure=true
RefreshToken__CookieSameSite=Strict
RefreshToken__CookiePath=/api/auth
