# Skopiuj do .env i dostosuj wartości. Plik .env jest ignorowany przez git.

# --- PostgreSQL ---
POSTGRES_USER=phonebook
POSTGRES_PASSWORD=phonebook
POSTGRES_DB=phonebook
POSTGRES_PORT=5432

# --- JWT (używane przez API od Fazy 2) ---
JWT__Issuer=PhoneBookApp
JWT__Audience=PhoneBookApp
JWT__Key=zmien-ten-klucz-na-dlugi-losowy-sekret-min-32-znaki
JWT__ExpiryMinutes=60
